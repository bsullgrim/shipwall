# Copy this file to ".env" and fill in your real values.
# The real ".env" is gitignored and never committed.
#
#   cp .env.example .env
#   # then edit .env with your key
#
# Load it before running the service:
#   set -a; source .env; set +a
#   python3 shipwall_service.py
#
# (or use the systemd unit, which reads these via Environment= lines)

# Your AISStream API key -- get a free one at https://aisstream.io
AISSTREAM_KEY=your_key_here

# IP/host of the ESP32 panel (or localhost:8080 when testing with mock_panel.py)
ESP32_HOST=192.168.1.50
SHIPWALL_LOG=ships.csv
REGISTER_LOG=register.csv