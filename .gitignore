# Source funnel photos: kept local, NOT committed. They're typically someone
# else's copyrighted photographs (e.g. from boatnerd); republishing them in a
# public repo would be redistribution. The generated ship_sprites.h is your
# own derived artifact and IS committed.
funnels/*.jpg
funnels/*.jpeg
funnels/*.png
funnels/*.webp
funnels/*.bmp

